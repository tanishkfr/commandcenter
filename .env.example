PORT=3000

# Optional local data directory. Defaults to .memory in the project.
REMAINDER_DATA_DIR=

# Optional for local development outside Vercel.
# Production Vercel deployments use VERCEL_OIDC_TOKEN automatically.
AI_GATEWAY_API_KEY=
AI_MODEL=google/gemini-2.5-flash-lite
AI_TIMEOUT_MS=12000

# Injected automatically when a Private Vercel Blob store is connected.
BLOB_READ_WRITE_TOKEN=
