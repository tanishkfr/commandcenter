# Optional. The product remains usable in local-intelligence mode without this.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Existing command/MCP API protection.
API_KEY=change-me

# Public deployment URL. Local development defaults to http://localhost:3000.
+PUBLIC_APP_URL=http://localhost:3000
+
+# Vercel Blob credentials are injected automatically when a private Blob store is connected.
+# Never commit BLOB_READ_WRITE_TOKEN.
